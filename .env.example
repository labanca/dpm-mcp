# GitHub Personal Access Token (optional)
# Used to access private repos and increase API rate limits.
# Required scopes for private repos: "repo" (or "contents:read" for fine-grained tokens).
# If unset, dpm-mcp uses unauthenticated requests (60/hour, public repos only).
GITHUB_TOKEN=

# Default output directory for downloaded datapackages
# (can be overridden per tool call)
DPM_MCP_OUTPUT_DIR=./datapackages

# HTTP timeout for downloads in seconds
DPM_MCP_HTTP_TIMEOUT=60

# --- Catalog ---

# Comma-separated list of catalog sources. Each entry is `org:NAME` or `user:NAME`.
# Bare names default to `org:`. Used by search_datapackages / get_catalog_summary
# when the caller doesn't pass an explicit `sources` argument.
DPM_MCP_CATALOG_SOURCES=org:splor-mg

# How long a built catalog stays in-memory before being rebuilt. Default 3600s = 1h.
DPM_MCP_CATALOG_TTL_SECONDS=3600

# --- HTTP transport (only needed when deploying as a remote MCP server) ---

# Transport: stdio (default, for local MCP clients), streamable-http, or sse.
DPM_MCP_TRANSPORT=stdio

# Bind address and port (for streamable-http/sse transports).
DPM_MCP_HOST=0.0.0.0
DPM_MCP_PORT=8000

# Bearer token clients must send as 'Authorization: Bearer <token>'.
# If unset, the HTTP endpoint accepts unauthenticated requests — only do this for local dev.
DPM_MCP_AUTH_TOKEN=
